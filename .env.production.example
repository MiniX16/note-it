# Copy this file to .env.production before deploying a tagged release.
COMPOSE_PROJECT_NAME=note-it
SERVER_IMAGE=minix16/note-it-server:1.0.0
CLIENT_IMAGE=minix16/note-it-client:1.0.0
SERVER_PORT=4000
CLIENT_PORT=4173
SERVER_DATA_VOLUME=note-it-data
DATABASE_URL=file:/data/app.db
CLIENT_URLS=https://app.example.com
JWT_SECRET=replace-with-a-strong-secret
