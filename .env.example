# Optional Docker Compose overrides for local development.
# Copy this file to .env only if you want to customize the defaults from the compose files.
COMPOSE_PROJECT_NAME=note-it
SERVER_IMAGE=minix16/note-it-server:latest
CLIENT_IMAGE=minix16/note-it-client:latest
SERVER_PORT=4000
CLIENT_PORT=4173
SERVER_DATA_VOLUME=note-it-data
DATABASE_URL=file:/data/app.db
CLIENT_URLS=http://localhost:4173
JWT_SECRET=change-this-secret
CLIENT_BUILD_API_URL=http://localhost:4000/api
